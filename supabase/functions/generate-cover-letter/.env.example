# Set as Edge Function secrets (Supabase Dashboard → Project → Edge Functions → Secrets), not in Vite .env
# If GEMINI_API_KEY is set, Gemini is used (Google AI Studio key). Otherwise OPENAI_API_KEY (OpenAI-compatible).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
